# --- CGI -----------------------------------------------------------------------
# Habilita la ejecución de scripts .cgi y los registra como CGI.
Options +ExecCGI
AddHandler cgi-script .cgi
DirectoryIndex index.cgi

# --- Rewrite: todas las rutas pasan por index.cgi con PATH_INFO -------------
# El router (app/router.py) hace match exacto de PATH_INFO, por ejemplo:
#   GET /login   -> PATH_INFO=/login
#   GET /        -> PATH_INFO=/
# Solo reescribir si el archivo o carpeta NO existe físicamente.
# Así info.cgi e index.cgi se ejecutan directamente; las rutas de la app van a index.cgi.
RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ /index.cgi/$1 [L]

# --- Seguridad: bloquear acceso directo a archivos sensibles ----------------
# El .env con credenciales nunca debe servirse como texto plano.
<FilesMatch "^\.env$">
    Require all denied
</FilesMatch>

# Tampoco el código fuente Python ni archivos de configuración.
<FilesMatch "\.(py|sql|cfg|ini)$">
    Require all denied
</FilesMatch>
