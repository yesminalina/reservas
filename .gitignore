# Entorno y secretos
.env
.venv/
venv/

# Bytecode Python
__pycache__/
*.py[cod]
*.pyo

# Artefactos de pruebas de carga
resultados_carga*
.pytest_cache/
htmlcov/
.coverage

# Distribuciones / empaquetados
dist/
build/
*.egg-info/

# vendor/ se versiona intencionalmente (PyMySQL vendorizado para CGI).
# Solo excluir bytecode dentro de vendor/.
vendor/**/__pycache__/
vendor/**/*.pyc
